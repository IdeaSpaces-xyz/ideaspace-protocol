{
  "name": "@ideaspaces/protocol",
  "version": "0.1.0",
  "description": "The Ideaspace Protocol — the platform-neutral shape of a knowledge repo. Spec, schema, reference library, and conformance kit.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/frontmatter": "./schema/frontmatter.schema.json",
    "./SPEC.md": "./SPEC.md",
    "./SKILLS.md": "./SKILLS.md"
  },
  "files": [
    "dist",
    "skills",
    "SPEC.md",
    "SKILLS.md",
    "schema",
    "VERSION"
  ],
  "scripts": {
    "embed-skills": "node scripts/embed-skills.mjs",
    "build": "npm run embed-skills && tsc",
    "dev": "npm run embed-skills && tsc --watch",
    "pretest": "npm run embed-skills",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/IdeaSpaces-xyz/ideaspace-protocol"
  }
}
